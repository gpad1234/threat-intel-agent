# Copy this to .env and fill in your API keys
# At minimum you need ONE LLM provider key

# ─── LLM Provider ─────────────────────────────────────
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxx
# OPENAI_API_KEY=sk-xxxxx
LLM_MODEL=claude-sonnet-4-20250514

# ─── Optional: Enhanced web search ────────────────────
# TAVILY_API_KEY=tvly-xxxxx

# ─── Agent Tuning ─────────────────────────────────────
CVE_LOOKBACK_DAYS=3
MAX_CVES_PER_RUN=50
MIN_CVSS_SCORE=5.0

# ─── Optional: Email Reports ──────────────────────────
EMAIL_ENABLED=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password-here
# EMAIL_TO=recipient@example.com

# ─── Target Host ──────────────────────────────────────────────────
DEPLOY_HOST=143.198.110.70

# ─── Local Activity Monitoring ────────────────────────────────────
# Enabled by default — the droplet has nginx serving an app on port 80.
# The agent reads logs only (never modifies nginx or any running service).
LOCAL_MONITORING_ENABLED=true

# ─── Safety: Protected Services ───────────────────────────────────
# nginx on port 80 has a valuable app deployed.
# The agent will NEVER suggest restarting nginx or modifying port 80.
# It will still REPORT nginx-related CVEs for manual review.
